# Required: Session mnemonic for the bot account
SESSION_MNEMONIC="your 13 word mnemonic here"

# Required: only this Session ID can message the bot
OWNER_SESSION_ID=05abc...

# AI provider API key (set at least one)
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# AI model (default: openai/gpt-4o)
# MODEL=openai/gpt-4o

# Ollama (free, local)
# OLLAMA_API_KEY=ollama-...
# OLLAMA_BASE_URL=http://localhost:11434/v1
